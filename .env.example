# TopZone Supabase Configuration
# Copy this file to .env and fill in your Supabase project credentials

# Supabase Project URL (e.g., https://yourproject.supabase.co)
PUBLIC_SUPABASE_URL=your_supabase_url_here

# Supabase Anon Public Key (safe for client-side use)
PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
