# TopZone Environment Variables
# Copy this file to .env and fill in your credentials

# Supabase (required for auth, database, and storage)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Midtrans Payment Gateway (required for checkout to work)
PUBLIC_MIDTRANS_CLIENT_KEY=your-client-key-here
MIDTRANS_SERVER_KEY=your-server-key-here
MIDTRANS_PRODUCTION=false

# Site URL (used for sitemap, redirects, and webhook callbacks)
SITE_URL=http://localhost:4321
