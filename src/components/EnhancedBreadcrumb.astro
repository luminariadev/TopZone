---
/**
 * Enhanced Breadcrumb Component
 * SVG arrow separators, current page highlight, dark mode support.
 */
interface BreadcrumbEntry {
  label: string;
  href?: string;
  isCurrent?: boolean;
}

interface Props {
  items: BreadcrumbEntry[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-sm font-bold dark:text-gray-300">
  <ol class="flex items-center flex-wrap gap-1">
    {items.map((item, index) => (
      <li class="flex items-center gap-1">
        {index > 0 && (
          <svg
            class="w-4 h-4 text-gray-400 flex-shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="3"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        )}
        {item.href && !item.isCurrent ? (
          <a
            href={item.href}
            class="px-2 py-1 border-2 border-transparent hover:border-black hover:bg-neon-yellow hover:text-black hover:shadow-[2px_2px_0px_0px_#000] hover:-translate-y-[1px] transition-all rounded-none"
          >
            {item.label}
          </a>
        ) : (
          <span
            class:list={[
              'px-2 py-1 border-2 border-black bg-neon-green text-black shadow-[2px_2px_0px_0px_#000]',
              { 'font-black uppercase tracking-wider text-xs': item.isCurrent },
            ]}
            aria-current={item.isCurrent ? 'page' : undefined}
          >
            {item.label}
          </span>
        )}
      </li>
    ))}
  </ol>
</nav>
