<!-- src/components/Marquee.astro -->
---
// Scrolling ticker component
---

<div class="overflow-hidden border-y-4 border-black bg-black py-3 select-none">
  <div class="marquee-track flex whitespace-nowrap gap-0">
    {[1, 2].map(() => (
      <span class="marquee-content inline-flex items-center gap-8 pr-8 text-neon-green font-black text-sm uppercase tracking-widest">
        <span>🎮 New Game Releases</span>
        <span class="text-neon-pink">✦</span>
        <span>⚙️ Gear Sale Up to 30%</span>
        <span class="text-neon-yellow">✦</span>
        <span>🚀 Instant Top-Up</span>
        <span class="text-neon-pink">✦</span>
        <span>🎉 Use Code: TOPZONE20</span>
        <span class="text-neon-yellow">✦</span>
        <span>💎 500K+ Transactions</span>
        <span class="text-neon-pink">✦</span>
        <span>🔥 Trusted by 200K Gamers</span>
        <span class="text-neon-yellow">✦</span>
      </span>
    ))}
  </div>
</div>

<style>
  @keyframes marquee-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .marquee-track {
    animation: marquee-scroll 25s linear infinite;
    width: max-content;
  }
  .marquee-track:hover {
    animation-play-state: paused;
  }
</style>
